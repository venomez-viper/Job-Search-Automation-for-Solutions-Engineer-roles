# ─────────────────────────────────────────────────────────
#  .env.example — Copy this to .env and fill in your values
#  DO NOT commit .env to Git. It is in .gitignore.
# ─────────────────────────────────────────────────────────

# Gmail SMTP credentials
# 1. Enable 2-Step Verification on your Google account
# 2. Go to: https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
EMAIL_SENDER=akashagakash@gmail.com
EMAIL_PASSWORD=your_16_char_app_password_here
EMAIL_RECIPIENT=akashagakash@gmail.com

# Google Sheets
# 1. Create a Google Sheet and copy its ID from the URL:
#    https://docs.google.com/spreadsheets/d/SHEET_ID_IS_HERE/edit
# 2. Share the sheet with your service account email (ends in @...gserviceaccount.com)
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account (paste the entire JSON on one line)
# 1. Go to: https://console.cloud.google.com/
# 2. Create project → Enable Sheets API + Drive API
# 3. Create Service Account → Download JSON key
# 4. Paste the entire JSON content here (as one line, no newlines)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@...gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
